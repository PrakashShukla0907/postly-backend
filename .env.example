# Postly - Environment Variables Configuration
# Copy this file to .env and fill in your values

# ============================================
# NODE.JS & SERVER
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================
# DATABASE (PostgreSQL required)
# ============================================
# PostgreSQL Connection String
# Format: postgresql://[user[:password]@][netloc][:port][/dbname]
DATABASE_URL=postgresql://user:password@localhost:5432/postly

# ============================================
# REDIS
# ============================================
# Redis Connection String
# For local development: redis://localhost:6379
# For production: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================
# JWT & AUTHENTICATION
# ============================================
# JWT secret for signing access tokens
# Generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_min_32_characters_required

# JWT secret for signing refresh tokens
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_characters

# Access token expiration time
JWT_EXPIRY=15m

# Refresh token expiration time
JWT_REFRESH_EXPIRY=7d

# ============================================
# ENCRYPTION
# ============================================
# AES-256 encryption key for sensitive fields
# Generate: openssl rand -hex 32
# This key is used to encrypt:
#   - social_accounts.access_token_enc
#   - social_accounts.refresh_token_enc
#   - ai_keys.openai_key_enc
#   - ai_keys.anthropic_key_enc
ENCRYPTION_KEY=your_encryption_key_64_hex_chars_required

# ============================================
# TELEGRAM BOT
# ============================================
# Bot token from @BotFather
# Example: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL where Telegram sends updates (production)
# Example: https://your-domain.com/webhook/telegram
# Leave empty for polling in development
TELEGRAM_WEBHOOK_URL=

# Secret token for webhook signature verification
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# AI PROVIDERS
# ============================================
# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Starts with: sk-...
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI Model to use
# Options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/account/keys
# Starts with: sk-ant-...
ANTHROPIC_API_KEY=sk-ant_your_anthropic_api_key_here

# Anthropic Model to use
# Options: claude-sonnet-4-5, claude-3-opus, claude-3-sonnet, claude-3-haiku
ANTHROPIC_MODEL=claude-sonnet-4-5

# ============================================
# SOCIAL PLATFORM APIs
# ============================================
# Twitter/X API Credentials (optional, for fallback)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# LinkedIn API Credentials (optional, for fallback)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Instagram API Credentials (optional, for fallback)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# ============================================
# RATE LIMITING
# ============================================
# Time window for rate limiting (milliseconds)
# 900000 = 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per user
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# QUEUE CONFIGURATION
# ============================================
# BullMQ job retry attempts
JOB_MAX_ATTEMPTS=3

# Base delay for exponential backoff (milliseconds)
JOB_BACKOFF_DELAY=1000

# ============================================
# SESSION MANAGEMENT
# ============================================
# Redis session TTL (seconds)
SESSION_TTL=1800

# Telegram bot conversation state TTL (seconds)
# 30 minutes
BOT_STATE_TTL=1800

# ============================================
# LOGGING
# ============================================
# Log level: debug, info, warn, error, fatal
LOG_LEVEL=debug

# Log format: json or text
LOG_FORMAT=text

# Enable request logging
LOG_REQUESTS=true

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# OPTIONAL: EMAIL NOTIFICATIONS
# ============================================
# Email provider for notifications
# Options: sendgrid, aws-ses, smtp
EMAIL_PROVIDER=smtp

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@postly.com

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ============================================
# OPTIONAL: ERROR TRACKING
# ============================================
# Sentry DSN for error tracking and monitoring
# Get from: https://sentry.io
SENTRY_DSN=

# ============================================
# OPTIONAL: ANALYTICS
# ============================================
# Enable analytics collection
ANALYTICS_ENABLED=false

# Google Analytics ID (if using Google Analytics)
GA_ID=

# ============================================
# OPTIONAL: FEATURE FLAGS
# ============================================
# Enable OAuth callback implementation
ENABLE_OAUTH_CALLBACKS=false

# Enable WhatsApp bot
ENABLE_WHATSAPP_BOT=false

# Enable scheduled post cron jobs
ENABLE_SCHEDULED_POSTS=true

# Enable analytics endpoint
ENABLE_ANALYTICS_API=false

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================
# Timezone for scheduled posts
TZ=UTC

# Database connection pool size
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis max connections
REDIS_MAX_RETRIES=10

# ============================================
# DEPLOYMENT SPECIFIC
# ============================================
# Base URL for API (used in documentation, links)
# Example: https://api.example.com
API_BASE_URL=http://localhost:3000

# Frontend URL (for CORS, redirects)
# Example: https://app.example.com
FRONTEND_URL=http://localhost:3000

# Environment name (for display in logs)
ENVIRONMENT_NAME=development

# ============================================
# NOTES
# ============================================
# 1. Replace all "your_..." values with actual credentials
# 2. Keep .env file secure - never commit to git
# 3. Use different keys for development and production
# 4. Generate strong secrets with: openssl rand -hex 32
# 5. Test all variables before deploying
# 6. Check platform rate limits and quotas
# 7. Monitor API usage and costs
